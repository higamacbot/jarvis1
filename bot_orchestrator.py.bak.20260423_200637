def init_orchestrator_db():
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute(
        """
        CREATE TABLE IF NOT EXISTS bot_status (
            bot_id TEXT PRIMARY KEY,
            status TEXT NOT NULL,
            current_task TEXT NOT NULL,
            last_updated TEXT NOT NULL
        )
        """
    )
    c.execute(
        """
        CREATE TABLE IF NOT EXISTS task_queue (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            bot_id TEXT NOT NULL,
            task TEXT NOT NULL,
            status TEXT NOT NULL DEFAULT 'pending',
            result TEXT NOT NULL DEFAULT '',
            created TEXT NOT NULL,
            completed TEXT
        )
        """
    )
    c.execute(
        """
        CREATE TABLE IF NOT EXISTS debate_history (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            topic TEXT NOT NULL,
            shaman_take TEXT NOT NULL,
            libmom_take TEXT NOT NULL,
            magadad_take TEXT NOT NULL,
            agreements TEXT NOT NULL,
            disagreements TEXT NOT NULL,
            narrative TEXT NOT NULL,
            created TEXT NOT NULL
        )
        """
    )
    now = datetime.now().isoformat()
    for bot_id in BOT_REGISTRY:
        c.execute(
            """
            INSERT OR IGNORE INTO bot_status (bot_id, status, current_task, last_updated)
            VALUES (?, ?, ?, ?)
            """,
            (bot_id, "idle", DEFAULT_TASKS.get(bot_id, "Waiting for next task."), now),
        )
    conn.commit()
    conn.close()


class TaskAssignment(BaseModel):
    bot_id: str
    task: str


class StatusUpdate(BaseModel):
    bot_id: str
    status: str
    task: Optional[str] = None


class DebateTrigger(BaseModel):
    topic: str


class BotOrchestrator:
    def get_all_statuses(self) -> dict:
        conn = sqlite3.connect(DB_PATH)
        c = conn.cursor()
        c.execute("SELECT bot_id, status, current_task, last_updated FROM bot_status ORDER BY bot_id")
        rows = c.fetchall()
        conn.close()
        result = {}
        for bot_id, status, current_task, last_updated in rows:
            meta = BOT_REGISTRY.get(bot_id, {"name": bot_id.upper(), "icon": "•"})
            result[bot_id] = {
                "name": meta["name"],
                "icon": meta["icon"],
                "status": status,
                "color": STATUS_TO_COLOR.get(status, "blue"),
                "current_task": current_task,
                "last_updated": last_updated,
            }
        return result

    def update_status(self, bot_id: str, status: str, task: Optional[str] = None):
        now = datetime.now().isoformat()
        conn = sqlite3.connect(DB_PATH)
        c = conn.cursor()
        if task is None:
            c.execute(
                "UPDATE bot_status SET status=?, last_updated=? WHERE bot_id=?",
                (status, now, bot_id),
            )
        else:
            c.execute(
                "UPDATE bot_status SET status=?, current_task=?, last_updated=? WHERE bot_id=?",
                (status, task, now, bot_id),
            )
        conn.commit()
        conn.close()

    def assign_task(self, bot_id: str, task: str) -> int:
        if bot_id not in BOT_REGISTRY:
            raise ValueError(f"Unknown bot: {bot_id}")
        now = datetime.now().isoformat()
        conn = sqlite3.connect(DB_PATH)
        c = conn.cursor()
        c.execute(
            "INSERT INTO task_queue (bot_id, task, status, created) VALUES (?, ?, 'pending', ?)",
            (bot_id, task, now),
        )
        task_id = c.lastrowid
        conn.commit()
        conn.close()
        self.update_status(bot_id, "working", task)
        return task_id

    def get_task_queue(self) -> List[Dict]:
        conn = sqlite3.connect(DB_PATH)
        c = conn.cursor()
        c.execute(
            "SELECT id, bot_id, task, status, result, created, completed FROM task_queue ORDER BY id DESC LIMIT 100"
        )
        rows = c.fetchall()
        conn.close()
        return [
            {
                "id": row[0],
                "bot_id": row[1],
                "task": row[2],
                "status": row[3],
                "result": row[4],
                "created": row[5],
                "completed": row[6],
            }
            for row in rows
        ]

    async def run_debate(self, topic: str) -> dict:
        takes = {}
        for name, persona in DEBATE_PERSONAS.items():
            takes[name] = await self._ollama_call(
                f"{persona['system']}\n\nTopic: {topic}\n\nRespond now:",
                timeout=90.0,
            )

        synthesis_prompt = f'''Compare these three viewpoints on: {topic}

SHAMAN:
{takes['conspiracy_shaman']}

LIB MOM:
{takes['lib_mom']}

MAGA DAD:
{takes['maga_dad']}

Task:
- Find 2 to 4 specific agreements shared across the viewpoints.
- Find 2 to 4 specific disagreements.
- Write one short neutral narrative summary.

Rules:
- Return valid JSON only.
- No markdown fences.
- Use this exact shape:
{{
  "agreements": ["..."],
  "disagreements": ["..."],
  "narrative": "..."
}}'''
        agreements = []
        disagreements = []
        narrative = "Debate complete. Review the three takes."
        raw = await self._ollama_call(synthesis_prompt, timeout=90.0)
        try:
            cleaned = raw.replace("```json", "").replace("```", "").strip()
            parsed = json.loads(cleaned)
            agreements = parsed.get("agreements", [])
            disagreements = parsed.get("disagreements", [])
            narrative = parsed.get("narrative", narrative)
        except Exception:
            cleaned = raw.replace("```json", "").replace("```", "").strip()
            try:
                agreements_match = re.search(r'"agreements"\s*:\s*\[(.*?)\]', cleaned, re.S)
                disagreements_match = re.search(r'"disagreements"\s*:\s*\[(.*?)\]', cleaned, re.S)
                narrative_match = re.search(r'"narrative"\s*:\s*"(.*?)"', cleaned, re.S)

                def parse_items(block):
                    if not block:
                        return []
                    items = re.findall(r'"(.*?)"', block)
                    return [i.strip() for i in items if i.strip()]

                agreements = parse_items(agreements_match.group(1) if agreements_match else "")
                disagreements = parse_items(disagreements_match.group(1) if disagreements_match else "")
                if narrative_match and narrative_match.group(1).strip():
                    narrative = narrative_match.group(1).strip()
            except Exception:
                fallback = await self._ollama_call(
                    f'''Summarize this debate on "{topic}" in plain text.

Return exactly this format:
AGREEMENTS:
- ...
- ...

DISAGREEMENTS:
- ...
- ...

NARRATIVE:
...

SHAMAN:
{takes["conspiracy_shaman"]}

LIB MOM:
{takes["lib_mom"]}

MAGA DAD:
{takes["magadad"] if "magadad" in takes else takes["maga_dad"]}''',
                    timeout=60.0,
                )
                agreements = re.findall(r'^-\s+(.*)$', fallback.split("DISAGREEMENTS:")[0], re.M)
                disagreement_block = ""
                if "DISAGREEMENTS:" in fallback:
                    disagreement_block = fallback.split("DISAGREEMENTS:", 1)[1].split("NARRATIVE:", 1)[0]
                disagreements = re.findall(r'^-\s+(.*)$', disagreement_block, re.M)
                if "NARRATIVE:" in fallback:
                    narrative = fallback.split("NARRATIVE:", 1)[1].strip() or narrative

        created = datetime.now().isoformat()
        conn = sqlite3.connect(DB_PATH)
        c = conn.cursor()
        c.execute(
            """
            INSERT INTO debate_history (topic, shaman_take, libmom_take, magadad_take, agreements, disagreements, narrative, created)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?)
            """,
            (
                topic,
                takes["conspiracy_shaman"],
                takes["lib_mom"],
                takes["maga_dad"],
                json.dumps(agreements),
                json.dumps(disagreements),
                narrative,
                created,
            ),
        )
        conn.commit()
        conn.close()
        return {
            "topic": topic,
            "shaman": takes["conspiracy_shaman"],
            "libmom": takes["lib_mom"],
            "magadad": takes["maga_dad"],
            "agreements": agreements,
            "disagreements": disagreements,
            "narrative": narrative,
            "created": created,
        }

    def get_debate_history(self) -> List[Dict]:
        conn = sqlite3.connect(DB_PATH)
        c = conn.cursor()
        c.execute(
            "SELECT id, topic, shaman_take, libmom_take, magadad_take, agreements, disagreements, narrative, created FROM debate_history ORDER BY id DESC LIMIT 20"
        )
        rows = c.fetchall()
        conn.close()
        history = []
        for row in rows:
            history.append(
                {
                    "id": row[0],
                    "topic": row[1],
                    "shaman": row[2],
                    "libmom": row[3],
                    "magadad": row[4],
                    "agreements": json.loads(row[5]) if row[5] else [],
                    "disagreements": json.loads(row[6]) if row[6] else [],
                    "narrative": row[7],
                    "created": row[8],
                }
            )
        return history

    async def background_worker(self):
        while True:
            try:
                task = self._fetch_next_task()
                if task is not None:
                    await self._process_task(*task)
            except Exception as exc:
                print(f">> ORCHESTRATOR WORKER ERROR: {exc}")
            await asyncio.sleep(5)

    def _fetch_next_task(self):
        conn = sqlite3.connect(DB_PATH)
        c = conn.cursor()
        c.execute(
            "SELECT id, bot_id, task FROM task_queue WHERE status='pending' ORDER BY id ASC LIMIT 1"
        )
        row = c.fetchone()
        if row:
            c.execute("UPDATE task_queue SET status='processing' WHERE id=?", (row[0],))
            conn.commit()
        conn.close()
        return row

    async def _process_task(self, task_id: int, bot_id: str, task: str):
        self.update_status(bot_id, "working", task)
        try:
            result = await self._handle_task(bot_id, task)
            self._complete_task(task_id, bot_id, result)
        except Exception as exc:
            self._fail_task(task_id, bot_id, str(exc))

    def _complete_task(self, task_id: int, bot_id: str, result: str):
        conn = sqlite3.connect(DB_PATH)
        c = conn.cursor()
        c.execute(
            "UPDATE task_queue SET status='completed', result=?, completed=? WHERE id=?",
            (result, datetime.now().isoformat(), task_id),
        )
        conn.commit()
        conn.close()
        self.update_status(bot_id, "review_ready", f"Task #{task_id} complete — review ready")

    def _fail_task(self, task_id: int, bot_id: str, error: str):
        conn = sqlite3.connect(DB_PATH)
        c = conn.cursor()
        c.execute(
            "UPDATE task_queue SET status='failed', result=?, completed=? WHERE id=?",
            (error, datetime.now().isoformat(), task_id),
        )
        conn.commit()
        conn.close()
        self.update_status(bot_id, "blocked", f"Task #{task_id} failed — {error[:80]}")

    async def _handle_task(self, bot_id: str, task: str) -> str:
        if bot_id == "jarvisbot" and ("youtube.com" in task or "youtu.be" in task):
            from youtube_tools import handle_youtube_request

            yt_result, yt_mode = await asyncio.to_thread(handle_youtube_request, task)
            if yt_mode == "youtube_summarize" and yt_result:
                return await self._ollama_call(
                    f"{YOUTUBE_TASK_PROMPT}\n\nYouTube data:\n{yt_result}",
                    timeout=120.0,
                )
            return yt_result or "No YouTube output generated."

        module_name = BOT_MODULES.get(bot_id)
        system_prompt = None
        if module_name:
            module = import_module(module_name)
            system_prompt = getattr(module, "SYSTEM_PROMPT", None)

        prompt = task if not system_prompt else f"{system_prompt}\n\nComplete this task succinctly and usefully:\n{task}"
        return await self._ollama_call(prompt, timeout=120.0)

    async def _ollama_call(self, prompt: str, timeout: float = 60.0) -> str:
        try:
            async with httpx.AsyncClient(timeout=timeout) as client:
                response = await client.post(
                    OLLAMA_URL,
                    json={"model": MODEL, "prompt": prompt, "stream": False},
                )
                return response.json().get("response", "Task complete.").strip()
        except Exception as exc:
            return f"Neural Link Error: {str(exc)[:100]}"


orchestrator = BotOrchestrator()


def register_routes(app):
    @app.get("/api/bots/status")
    async def api_bot_statuses():
        return JSONResponse(orchestrator.get_all_statuses())

    @app.post("/api/bots/status")
    async def api_update_bot_status(update: StatusUpdate):
        orchestrator.update_status(update.bot_id, update.status, update.task)
        return JSONResponse({"ok": True})

    @app.get("/api/bots/tasks")
    async def api_bot_tasks():
        return JSONResponse(orchestrator.get_task_queue())

    @app.post("/api/bots/tasks")
    async def api_assign_task(assignment: TaskAssignment):
        task_id = orchestrator.assign_task(assignment.bot_id, assignment.task)
        return JSONResponse({"ok": True, "task_id": task_id})

    @app.post("/api/debate/trigger")
    async def api_trigger_debate(trigger: DebateTrigger):
        return JSONResponse(await orchestrator.run_debate(trigger.topic))

    @app.get("/api/debate/history")
    async def api_debate_history():
        return JSONResponse(orchestrator.get_debate_history())
